<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- CS 1.6 / GoldSrc Color Palette -->
    <Color x:Key="Color_Background">#4C5844</Color>
    <Color x:Key="Color_Control">#3E4637</Color>
    <Color x:Key="Color_BorderLight">#768D69</Color>
    <Color x:Key="Color_BorderDark">#293025</Color>
    <Color x:Key="Color_Text">#D2DBCF</Color>
    <Color x:Key="Color_TextHighlight">#BBE216</Color> <!-- The distinct CS "bright green" -->
    <Color x:Key="Color_TextDim">#96AA89</Color>
    <Color x:Key="Color_Selection">#65755B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background}" />
    <SolidColorBrush x:Key="Brush_Control" Color="{StaticResource Color_Control}" />
    <SolidColorBrush x:Key="Brush_BorderLight" Color="{StaticResource Color_BorderLight}" />
    <SolidColorBrush x:Key="Brush_BorderDark" Color="{StaticResource Color_BorderDark}" />
    <SolidColorBrush x:Key="Brush_Text" Color="{StaticResource Color_Text}" />
    <SolidColorBrush x:Key="Brush_TextHighlight" Color="{StaticResource Color_TextHighlight}" />
    <SolidColorBrush x:Key="Brush_TextDim" Color="{StaticResource Color_TextDim}" />
    <SolidColorBrush x:Key="Brush_Selection" Color="{StaticResource Color_Selection}" />

    <!-- Fonts -->
    <FontFamily x:Key="Font_Main">Microsoft Sans Serif, Tahoma, Verdana</FontFamily>
    <FontFamily x:Key="Font_Mono">Consolas, Courier New</FontFamily>
    <System:Double x:Key="FontSize_Normal" xmlns:System="clr-namespace:System;assembly=mscorlib">11</System:Double>
    <System:Double x:Key="FontSize_Header" xmlns:System="clr-namespace:System;assembly=mscorlib">14</System:Double>

    <!-- Base Control Style -->
    <Style TargetType="Control" x:Key="BaseStyle">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
    </Style>

    <!-- Bevel Border Style (Inset) -->
    <Style x:Key="BorderStyle_Inset" TargetType="Border">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Color_BorderDark}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Color_BorderDark}" Offset="0.5" />
                    <GradientStop Color="{StaticResource Color_BorderLight}" Offset="0.5" />
                    <GradientStop Color="{StaticResource Color_BorderLight}" Offset="1.0" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Better Bevel (2-pass via ControlTemplate usually, but simple border here) -->
    <!-- We'll simulate VGUI borders with specific border styles on controls -->

    <!-- BUTTON -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="Background" Value="#4C5844" />
        <Setter Property="BorderThickness" Value="2" /> <!-- Thick bevel -->
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.BorderBrush>
                            <!-- Fake 3D Bevel: Light Top/Left, Dark Bottom/Right -->
                            <!-- Since we can't easily do 4-color border in one prop, we use nested borders or VisualBrush.
                                 Simplest XAML way: Top/Left = Light, Bottom/Right = Dark. 
                                 Standard Checkbox style. -->
                             <DrawingBrush Viewport="0,0,1,1" TileMode="None">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="{StaticResource Brush_BorderLight}">
                                            <GeometryDrawing.Geometry>
                                                <PathGeometry Figures="M0,0 L1,0 L0,1 Z" /> <!-- Top Left Triangle?? No. -->
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <!-- Wait, drawing brush is complex for border. Let's use standard Border properties if possible or a Grid. -->
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.BorderBrush>
                        
                        <!-- Use a Grid with two borders for bevel effect -->
                        <Grid>
                            <!-- Light Top/Left -->
                            <Border BorderThickness="2,2,0,0" BorderBrush="{StaticResource Brush_BorderLight}" />
                            <!-- Dark Bottom/Right -->
                            <Border BorderThickness="0,0,2,2" BorderBrush="{StaticResource Brush_BorderDark}" />
                            
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="Background" Value="#5D6B53" /> <!-- Lighter on hover -->
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#3E4637" />
                            <!-- Invert bevel -->
                            <Setter TargetName="border" Property="BorderBrush" Value="Transparent" /> 
                            <!-- We can't swap the nested borders easily without naming them. 
                                 Let's redesign template to use named parts. -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TEXTBOX -->
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="Background" Value="#353D30" /> <!-- Darker inset -->
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <!-- Inset Bevel -->
                        <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" />
                        <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderLight}" />
                        
                        <ScrollViewer x:Name="PART_ContentHost" Margin="2" Background="{TemplateBinding Background}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- COMBO BOX -->
    <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="20" />
            </Grid.ColumnDefinitions>
            <!-- Inset Bevel for Main Box -->
            <Border Grid.ColumnSpan="2" BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" Background="{StaticResource Brush_Control}" />
            <Border Grid.ColumnSpan="2" BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderLight}" />
            
            <Border Grid.Column="0" Background="Transparent" Margin="1" />
            <Border Grid.Column="1" Margin="1,1,1,1" Background="{StaticResource Brush_Background}" BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderLight}">
                <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderDark}">
                    <Path x:Name="Arrow" Fill="{StaticResource Brush_TextDim}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L8,0 L4,4 Z"/>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="true">
                <Setter Property="Fill" TargetName="Arrow" Value="{StaticResource Brush_TextHighlight}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="true">
                <Setter Property="Fill" TargetName="Arrow" Value="{StaticResource Brush_TextHighlight}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ComboBoxTextBox" TargetType="{x:Type TextBox}">
        <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
    </ControlTemplate>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}"
                                      Grid.Column="2" Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="6,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,3,23,3"
                                 Focusable="True" Background="Transparent" Foreground="Green" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}" />
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" Background="{StaticResource Brush_Control}" BorderThickness="1" BorderBrush="{StaticResource Brush_BorderLight}" />
                                <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="false">
                            <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95" />
                        </Trigger>
                        <Trigger Property="IsGrouping" Value="true">
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="true">
                            <Setter Property="IsTabStop" Value="false" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Border" Padding="2" SnapsToDevicePixels="true" Background="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource Brush_Selection}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="{StaticResource Brush_TextDim}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

     <!-- LABEL / TEXTBLOCK -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
    </Style>
    
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
    </Style>

    <!-- SCROLLBAR -->
    <!-- SCROLLBAR THUMB -->
    <Style x:Key="GoldSrcThumb" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource Brush_Background}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" />
                        <!-- Bevel -->
                        <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderLight}" />
                        <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderDark}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SCROLLBAR REPEAT BUTTON (Track) -->
    <Style x:Key="GoldSrcRepeatButton" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Grid>
                        <!-- Inset bevel for the track -->
                        <Border Background="{StaticResource Brush_Control}" />
                        <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" />
                        <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderLight}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SCROLLBAR ARROW BUTTON -->
    <Style x:Key="GoldSrcArrowButton" TargetType="RepeatButton">
        <Setter Property="Background" Value="{StaticResource Brush_Background}" />
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" />
                        <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderLight}" />
                        <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderDark}" />
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                             <Setter Property="Background" Value="{StaticResource Brush_Control}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MAIN SCROLLBAR TEMPLATE -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource Brush_Control}" />
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_BorderDark}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="14" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition MaxHeight="14" />
                                        <RowDefinition Height="0.00001*" />
                                        <RowDefinition MaxHeight="14" />
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Up Arrow -->
                                    <RepeatButton Style="{StaticResource GoldSrcArrowButton}" Command="ScrollBar.LineUpCommand">
                                        <Path Data="M0,4 L8,4 L4,0 Z" Fill="{StaticResource Brush_TextDim}" Margin="0,1,0,0" />
                                    </RepeatButton>
                                    
                                    <!-- Track -->
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GoldSrcRepeatButton}" Command="ScrollBar.PageUpCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource GoldSrcThumb}" MinHeight="14" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GoldSrcRepeatButton}" Command="ScrollBar.PageDownCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    
                                    <!-- Down Arrow -->
                                    <RepeatButton Grid.Row="2" Style="{StaticResource GoldSrcArrowButton}" Command="ScrollBar.LineDownCommand">
                                        <Path Data="M0,0 L8,0 L4,4 Z" Fill="{StaticResource Brush_TextDim}" Margin="0,1,0,0"/>
                                    </RepeatButton>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="14" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition MaxWidth="14" />
                                        <ColumnDefinition Width="0.00001*" />
                                        <ColumnDefinition MaxWidth="14" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left Arrow -->
                                    <RepeatButton Style="{StaticResource GoldSrcArrowButton}" Command="ScrollBar.LineLeftCommand">
                                        <Path Data="M4,0 L4,8 L0,4 Z" Fill="{StaticResource Brush_TextDim}" Margin="1,0,0,0"/>
                                    </RepeatButton>
                                    
                                    <!-- Track -->
                                    <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GoldSrcRepeatButton}" Command="ScrollBar.PageLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource GoldSrcThumb}" MinWidth="14" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GoldSrcRepeatButton}" Command="ScrollBar.PageRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    
                                    <!-- Right Arrow -->
                                    <RepeatButton Grid.Column="2" Style="{StaticResource GoldSrcArrowButton}" Command="ScrollBar.LineRightCommand">
                                        <Path Data="M0,0 L0,8 L4,4 Z" Fill="{StaticResource Brush_TextDim}" Margin="1,0,0,0"/>
                                    </RepeatButton>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- GROUPBOX -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_BorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid SnapsToDevicePixels="true">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="1" BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderLight}">
                            <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderDark}">
                                <ContentPresenter Margin="6" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Border>
                        <Border Grid.Row="0" Margin="10,0,0,-7" HorizontalAlignment="Left" Background="{StaticResource Brush_Background}" Padding="3,0">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PROGRESS BAR -->
    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="#BBE216" /> <!-- CS Grid Yellow/Green -->
        <Setter Property="Background" Value="#293025" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush_BorderDark}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                 <ControlTemplate TargetType="ProgressBar">
                     <Grid>
                        <!-- Inset border -->
                        <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" />
                        <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderLight}" />
                        
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}" Margin="1" />
                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" Margin="1" />
                     </Grid>
                 </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TREE VIEW -->
    <Style TargetType="TreeView">
        <Setter Property="Background" Value="#353D30" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="BorderThickness" Value="0" />
        <!-- ItemContainerStyle is needed for selection color -->
    </Style>
    
    <!-- Expand/Collapse Toggle Button (The little + / - box) -->
    <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Width="9" Height="9" Background="{StaticResource Brush_Background}" BorderBrush="{StaticResource Brush_Text}" BorderThickness="1">
                        <Path x:Name="ExpandPath" Data="M0,4 L8,4 M4,0 L4,8" Stroke="{StaticResource Brush_Text}" StrokeThickness="1" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                             <Setter TargetName="ExpandPath" Property="Data" Value="M0,4 L8,4"/> <!-- Minus -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="19" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        
                        <ToggleButton x:Name="Expander" Style="{StaticResource ExpandCollapseToggleStyle}" 
                                      ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"/>
                        
                        <Border x:Name="Bd" Grid.Column="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        
                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Fix for default WPF TreeView white background on selection -->
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush_Selection}"/>
                            <Setter TargetName="Bd" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="false">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- TAB CONTROL -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="#3E4637"/> <!-- Color_Control -->
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_BorderLight}"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="Background" Value="#4C5844" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Margin="0,0,2,0"> <!-- Removed bottom margin, handle spacing via Grid/Container if needed, or just let it sit -->
                        <Border.BorderBrush>
                            <SolidColorBrush Color="Transparent"/>
                        </Border.BorderBrush>
                        
                        <!-- Use a Grid with two borders for bevel effect -->
                        <Grid>
                            <!-- Light Top/Left -->
                            <Border BorderThickness="2,2,0,0" BorderBrush="{StaticResource Brush_BorderLight}" />
                            <!-- Dark Bottom/Right -->
                            <Border BorderThickness="0,0,2,2" BorderBrush="{StaticResource Brush_BorderDark}" />
                            
                            <ContentPresenter x:Name="ContentSite" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center" 
                                            ContentSource="Header"
                                            Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                             <Setter Property="Background" Value="#3E4637" />
                             <Setter Property="Foreground" Value="{StaticResource Brush_TextHighlight}" />
                             <Setter Property="Panel.ZIndex" Value="1" />
                        </Trigger>
                        
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="Background" Value="#5D6B53" />
                         </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CHECKBOX -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" /> <!-- Reasonable default spacing -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <!-- Box -->
                        <Grid Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center">
                            <!-- Inset Bevel -->
                            <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" Background="{StaticResource Brush_Control}" />
                            <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderLight}" />
                            <!-- Checkmark -->
                            <Path x:Name="CheckMark" Data="M2.5,6.5 L5,9 L10.5,3.5" Stroke="{StaticResource Brush_TextHighlight}" StrokeThickness="2" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <!-- Text -->
                        <ContentPresenter VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Brush_TextDim}" />
                            <Setter TargetName="CheckMark" Property="Stroke" Value="{StaticResource Brush_TextDim}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CONTEXT MENU & MENU ITEM -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#3E4637" /> <!-- Or Brush_Control -->
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="FontFamily" Value="{StaticResource Font_Main}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Grid>
                        <!-- Shadow effect (optional, native menus cast shadow) -->
                        <Border Background="Transparent" Margin="0,0,3,3" />
                        
                        <Border Background="{TemplateBinding Background}" Margin="0,0,3,3">
                            <Grid>
                                <!-- Outset Bevel -->
                                <Border BorderThickness="1,1,0,0" BorderBrush="{StaticResource Brush_BorderLight}" />
                                <Border BorderThickness="0,0,1,1" BorderBrush="{StaticResource Brush_BorderDark}" />
                                
                                <ScrollViewer Margin="1" Uid="ScrollViewer">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" Margin="1" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="16,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter x:Name="HeaderContent" ContentSource="Header" RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush_Selection}" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Brush_TextDim}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Named Style for Separators in Menus -->
    <Style TargetType="Separator" x:Key="{x:Static MenuItem.SeparatorStyleKey}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Grid Height="2" Margin="4,3">
                        <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource Brush_BorderDark}" />
                        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource Brush_BorderLight}" Margin="0,1,0,0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
