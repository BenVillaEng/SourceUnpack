<Window x:Class="SourceUnpack.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="400"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource Brush_Background}"
            BorderThickness="2" BorderBrush="{StaticResource Brush_BorderLight}"
            Padding="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="{StaticResource Brush_Background}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title Text -->
                <TextBlock Text="Settings" 
                           Foreground="{StaticResource Brush_Text}" 
                           FontFamily="{StaticResource Font_Main}" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>

                <!-- Window Helpers -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,2,0">
                    <Button Content="X" Width="20" Height="20" Padding="0" Click="CloseButton_Click"
                             Style="{StaticResource {x:Type Button}}" 
                             FontFamily="Arial" FontWeight="Bold" FontSize="10" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <GroupBox Header="CONVERSION SETTINGS" Grid.Row="0" Style="{StaticResource {x:Type GroupBox}}" Margin="0,0,0,8">
                    <StackPanel Margin="0,8,0,0">
                        <CheckBox Content="KEEP MDL FILE" 
                                  IsChecked="{Binding KeepMdlFile}" 
                                  Margin="0,0,0,8" Foreground="{StaticResource Brush_Text}" />
                                  
                        <CheckBox Content="PRESERVE DIRECTORY STRUCTURE" 
                                  IsChecked="{Binding PreserveDirectoryStructure}" 
                                  Foreground="{StaticResource Brush_Text}" />
                    </StackPanel>
                </GroupBox>
                
                <!-- Bottom button panel -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Close" Width="80" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
