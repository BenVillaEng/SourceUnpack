<Window x:Class="SourceUnpack.App.Views.WizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SourceUnpack.App.Views"
        mc:Ignorable="d"
        Title="Welcome to SourceUnpack" Height="400" Width="600"
        Background="{StaticResource PrimaryBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="SourceUnpack" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="First-Time Setup" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Game Directory (VPK Access)" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Point to your Garry's Mod or HL2 directory to allow VPK mounting." 
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GameDirBox" IsReadOnly="True" Text="C:\Program Files (x86)\Steam\steamapps\common\GarrysMod"/>
                <Button Grid.Column="1" Content="..." Width="30" Margin="8,0,0,0" Click="BrowseGameDir_Click" Style="{StaticResource SourceButton}"/>
            </Grid>

            <TextBlock Text="Default Output Directory" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputDirBox" IsReadOnly="True" Text="{Binding OutputDirectory, Mode=OneWay}"/>
                <Button Grid.Column="1" Content="..." Width="30" Margin="8,0,0,0" Click="BrowseOutputDir_Click" Style="{StaticResource SourceButton}"/>
            </Grid>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Finish" Width="100" Click="Finish_Click" Style="{StaticResource AccentButton}"/>
        </StackPanel>
    </Grid>
</Window>
